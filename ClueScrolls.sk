every 1 second:
    loop all players:
        set {_p}   to loop-player
        set {_uid} to cs_get_uid({_p})
        if {_uid} is not set:
            continue
        if {_uid} is "":
            continue

        if {_p} is swimming:
            set {_cid} to cs_get_active_clue_if_type({_p}, "swim")
            if {_cid} is not "":
                set {_need} to {cs::clues::%{cs::session::%{_uid}%::tier}%::%{_cid}%::amount}
                set {_prog} to {cs::session::%{_uid}%::progress::%{_cid}%}
                if {_prog} < {_need}:
                    add 1 to {cs::session::%{_uid}%::progress::%{_cid}%}
                    cs_update_scroll_lore({_p})
                    cs_check_clue_complete({_p}, {_cid})

        if remaining air of {_p} < 0.3 seconds:
            set {_cid2} to cs_get_active_clue_if_type({_p}, "dive")
            if {_cid2} is not "":
                set {_need2} to {cs::clues::%{cs::session::%{_uid}%::tier}%::%{_cid2}%::amount}
                set {_prog2} to {cs::session::%{_uid}%::progress::%{_cid2}%}
                if {_prog2} < {_need2}:
                    add 1 to {cs::session::%{_uid}%::progress::%{_cid2}%}
                    cs_update_scroll_lore({_p})
                    cs_check_clue_complete({_p}, {_cid2})

