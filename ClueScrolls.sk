        cs_update_scroll_lore(player)
        cs_check_clue_complete(player, {_cid})

on pickup:
    set {_cid} to cs_get_active_clue_if_type(player, "collect")
    if {_cid} is "":
        stop
    set {_uid}    to cs_get_uid(player)
    set {_tier}   to {cs::session::%{_uid}%::tier}
    set {_target} to {cs::clues::%{_tier}%::%{_cid}%::target}
    set {_item}   to "%type of event-item%" in lowercase
    set {_count}  to amount of event-item
    if cs_target_matches({_target}, {_item}) is true:
        set {_need} to {cs::clues::%{_tier}%::%{_cid}%::amount}
        set {_prog} to {cs::session::%{_uid}%::progress::%{_cid}%}
        if {_prog} < {_need}:
            add {_count} to {cs::session::%{_uid}%::progress::%{_cid}%}
            cs_update_scroll_lore(player)
            cs_check_clue_complete(player, {_cid})

# Mengecek apakah progress clue sudah mencapai jumlah yang ditentukan.
# Apabila ya, clue ditandai selesai, statistik player diperbarui, notifikasi dikirim,
# kemudian memanggil "cs_check_scroll_complete()".
# Terdapat guard untuk mencegah clue yang sama dihitung lebih dari sekali.
function cs_check_clue_complete(p: player, cid: string):
    set {_uid}  to cs_get_uid({_p})
    if {_uid} is not set:
        stop
    if {_uid} is "":
        stop
    set {_tier} to {cs::session::%{_uid}%::tier}
    set {_prog} to {cs::session::%{_uid}%::progress::%{_cid}%}
    set {_need} to {cs::clues::%{_tier}%::%{_cid}%::amount}
    set {_desc} to {cs::clues::%{_tier}%::%{_cid}%::desc}

    if {_prog} < {_need}:
        stop

    if {cs::session::%{_uid}%::done::%{_cid}%} is set:
        stop

    set {cs::session::%{_uid}%::done::%{_cid}%} to true
    add 1 to {cs::session::%{_uid}%::completed}

    play sound "entity.player.levelup" with volume 0.6 and pitch 1.2 to {_p}
    set {_doneNow}  to {cs::session::%{_uid}%::completed}
    set {_totalNow} to {cs::session::%{_uid}%::total}

    send "" to {_p}
    send "&f&m                                  " to {_p}
    send "  &a✔ &fClue Selesai!" to {_p}
    send "" to {_p}
    send "  &fTugas: &a%{_desc}%" to {_p}
    send "  &fProgres: &f%{_doneNow}% &7/ &f%{_totalNow}% clue" to {_p}
    if {_doneNow} < {_totalNow}:
        send "  &a✦ &fKlik Kanan scrollmu untuk mulai clue berikutnya!" to {_p}
    send "&f&m                                  " to {_p}
    send "" to {_p}

    delete {cs::session::%{_uid}%::current_clue}

    add 1 to {cs::stats::%{_p}'s uuid%::clues_completed}
    add 1 to {cs::stats::%{_p}'s uuid%::clues_%{_tier}%}

    cs_update_scroll_lore({_p})
    cs_check_scroll_complete({_p})

# Mengecek apakah semua clue dalam sesi sudah selesai.
# Apabila ya, memanggil "cs_complete_scroll()".
function cs_check_scroll_complete(p: player):
    set {_uid}   to cs_get_uid({_p})
    if {_uid} is not set:
        stop
    if {_uid} is "":
        stop
    set {_done}  to {cs::session::%{_uid}%::completed}
    set {_total} to {cs::session::%{_uid}%::total}
    if {_done} >= {_total}:
        cs_complete_scroll({_p})

# Menyelesaikan scroll player secara penuh.
# Memberikan reward sebanyak 2x untuk tier easy/medium dan 3x untuk hard,
# dipilih menggunakan weighted random. Item scroll dihapus dari inventory,
# statistik player diperbarui, broadcast dikirim ke seluruh server,
# sesi dihapus, dan timestamp cooldown disimpan.
function cs_complete_scroll(p: player):
    set {_uid}     to cs_get_uid({_p})
    if {_uid} is not set:
        stop
    if {_uid} is "":
        stop
    set {_tier}    to {cs::session::%{_uid}%::tier}
    set {_display} to cs_tier_display({_tier})

    play sound "ui.toast.challenge_complete" with volume 1 and pitch 1 to {_p}
    send title "&6&l✦ SCROLL SELESAI!" with subtitle "&fReward %{_display}% &ftelah diberikan!" to {_p} for 4 seconds

    send "" to {_p}
    send "&f&m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━" to {_p}
    send "    &6✦ &f&lCLUE SCROLL SELESAI! &6✦" to {_p}
    send "&f&m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━" to {_p}
    send "" to {_p}
    send "  &fTier    : %{_display}%" to {_p}
    send "  &fPemain  : &f%name of {_p}%" to {_p}
    send "" to {_p}
    send "  &f&lREWARD:" to {_p}

    set {_numRewards} to 2
    if {_tier} is "hard":
        set {_numRewards} to 3

    loop {_numRewards} times:
        set {_rname} to cs_pick_reward({_tier})
        if {_rname} is not "":
            set {_rtype} to {cs::rewards::%{_tier}%::%{_rname}%::type}
            set {_rval}  to {cs::rewards::%{_tier}%::%{_rname}%::value}
            if {_rtype} is "command":
                set {_cmd}   to {_rval}
                set {_pname} to name of {_p}
                replace all "{player}" in {_cmd} with {_pname}
                execute console command {_cmd}
                send "  &a✔ &fReward diberikan!" to {_p}

    send "" to {_p}
    send "&f&m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━" to {_p}
    send "" to {_p}

    add 1 to {cs::stats::%{_p}'s uuid%::scrolls_completed}
    add 1 to {cs::stats::%{_p}'s uuid%::scrolls_%{_tier}%}

    broadcast "%{cs::config::prefix}%&f%name of {_p}% &7telah menyelesaikan &f%{_display}%&7 Clue Scroll!"

    loop integers from 0 to 35:
        set {_curSlot} to loop-integer
        set {_s}       to slot {_curSlot} of {_p}'s inventory
        if name of {_s} contains "Clue Scroll":
            set {_slore::*} to lore of {_s}
            loop {_slore::*}:
                if loop-value-2 contains "uid:":
                    set {_checkUid} to loop-value-2
                    replace all "&8" in {_checkUid} with ""
                    replace all "§8" in {_checkUid} with ""
                    replace all "uid:" in {_checkUid} with ""
                    replace all " " in {_checkUid} with ""
                    if {_checkUid} is {_uid}:
                        set slot {_curSlot} of {_p}'s inventory to air
                        delete {_slore::*}
                        stop loop
            delete {_slore::*}

    cs_pause_session({_p})
    cs_delete_session({_uid})
    set {cs::cooldown::%{_p}'s uuid%::%{_tier}%} to now

# Menampilkan progress scroll aktif milik player di chat.
# Menampilkan semua clue beserta status selesai atau belum dan progress saat ini.
function cs_show_scroll(p: player):
    set {_uid} to cs_get_uid({_p})
    if {_uid} is not set:
        send "%{cs::config::prefix}%&fKamu tidak punya scroll aktif." to {_p}
        stop
    if {_uid} is "":
        send "%{cs::config::prefix}%&fKamu tidak punya scroll aktif." to {_p}
        stop

    set {_tier}  to {cs::session::%{_uid}%::tier}
    set {_done}  to {cs::session::%{_uid}%::completed}
    set {_total} to {cs::session::%{_uid}%::total}

    send "&8&m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━" to {_p}
    send " &6✦ &lClue Scroll &7[%cs_tier_display({_tier})%&7]" to {_p}
    send " &7Progress: &f%{_done}%&7/&f%{_total}%" to {_p}
    send "" to {_p}

    loop {cs::session::%{_uid}%::clues::*}:
        set {_cid}  to loop-value
        set {_prog} to {cs::session::%{_uid}%::progress::%{_cid}%}
        set {_need} to {cs::clues::%{_tier}%::%{_cid}%::amount}
        set {_desc} to {cs::clues::%{_tier}%::%{_cid}%::desc}
        if {_prog} >= {_need}:
            send " &a✔ &m%{_desc}%" to {_p}
        else:
            send " &c✘ &f%{_desc}% &7(%{_prog}%/%{_need}%)" to {_p}

    send "&8&m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━" to {_p}

# Mengecek apakah player masih dalam masa cooldown untuk tier tertentu.
# Apabila masih cooldown, mengirim pesan sisa waktu ke player dan mengembalikan "false".
# Mengembalikan "true" apabila player sudah boleh membuka scroll kembali.
function cs_check_cooldown(p: player, tier: string) :: boolean:
    set {_cd} to {cs::config::cooldown::%{_tier}%}
    if {_cd} is 0:
        return true
    set {_last} to {cs::cooldown::%{_p}'s uuid%::%{_tier}%}
    if {_last} is not set:
        return true
    set {_elapsed}    to difference between {_last} and now
    set {_elapsedSec} to {_elapsed} / 1 second
    if {_elapsedSec} >= {_cd}:
        return true
    set {_remain} to {_cd} - {_elapsedSec}
    send "%{cs::config::prefix}%&fCooldown! Tunggu &f%{_remain}% &fdetik lagi." to {_p}
    return false

command /cluescrolls [<text>] [<text>] [<text>] [<text>]:
    aliases: /cs, /clue
    trigger:
        cs_command(player, arg-1, arg-2, arg-3, arg-4)

# Handler utama untuk semua subcommand "/cs".
# Meneruskan eksekusi ke fungsi yang sesuai berdasarkan argumen pertama.
# Subcommand yang didukung: "scroll", "abandon", "stats", "leaderboard",
# "give", "reload", "forcecomplete", dan "resetcooldown".
function cs_command(p: player, a1: string, a2: string, a3: string, a4: string):
    if {_a1} is not set:
        send "%{cs::config::prefix}%&7Penggunaan:" to {_p}
        send "  &f/cs give <player> <tier> &7- Beri scroll [OP]" to {_p}
        send "  &f/cs scroll &7- Tampilkan progress" to {_p}
        send "  &f/cs stats [player] &7- Lihat statistik" to {_p}
        send "  &f/cs abandon &7- Tinggalkan scroll aktif" to {_p}
        send "  &f/cs reload &7- Reload konfigurasi [OP]" to {_p}
        send "  &f/cs leaderboard &7- Top pemain" to {_p}
        stop

    if {_a1} is "scroll":
        cs_show_scroll({_p})
        stop

    set {_isAbandon} to false
    if {_a1} is "abandon":
        set {_isAbandon} to true
    if {_a1} is "drop":
        set {_isAbandon} to true
    if {_isAbandon} is true:
        set {_uid} to cs_get_uid({_p})
        if {_uid} is not set:
            send "%{cs::config::prefix}%&fKamu tidak punya scroll aktif." to {_p}
            stop
        if {_uid} is "":
            send "%{cs::config::prefix}%&fKamu tidak punya scroll aktif." to {_p}
            stop
        cs_pause_session({_p})
        cs_delete_session({_uid})
        send "%{cs::config::prefix}%&fScroll ditinggalkan." to {_p}
        stop

    set {_isStats} to false
    if {_a1} is "stats":
        set {_isStats} to true
    if {_a1} is "statistics":
        set {_isStats} to true
    if {_isStats} is true:
        if {_a2} is set:
            if {_p} doesn't have permission "cluescrolls.admin":
                send "%{cs::config::prefix}%&fKamu tidak punya izin untuk melihat stats orang lain." to {_p}
                stop
            set {_target} to {_a2} parsed as player
            if {_target} is not set:
                send "%{cs::config::prefix}%&fPlayer %{_a2}% tidak ditemukan." to {_p}
                stop
            cs_show_stats({_p}, {_target})
        else:
            cs_show_stats({_p}, {_p})
        stop

    set {_isLb} to false
    if {_a1} is "leaderboard":
        set {_isLb} to true
    if {_a1} is "lb":
        set {_isLb} to true
    if {_a1} is "top":
        set {_isLb} to true
    if {_isLb} is true:
        cs_show_leaderboard({_p})
        stop

    if {_a1} is "give":
        if {_p} doesn't have permission "cluescrolls.give":
            if {_p} is not op:
                send "%{cs::config::prefix}%&fKamu tidak punya izin." to {_p}
                stop
        set {_missingArgs} to false
        if {_a2} is not set:
            set {_missingArgs} to true
        if {_a3} is not set:
            set {_missingArgs} to true
        if {_missingArgs} is true:
            send "%{cs::config::prefix}%&fPenggunaan: &f/cs give <player> <easy|medium|hard>" to {_p}
            stop
        set {_target} to {_a2} parsed as player
        if {_target} is not set:
            send "%{cs::config::prefix}%&fPlayer %{_a2}% tidak ditemukan." to {_p}
            stop
        set {_tier} to {_a3} in lowercase
        if {_tier} is not "easy":
            if {_tier} is not "medium":
                if {_tier} is not "hard":
                    send "%{cs::config::prefix}%&fTier tidak valid! Gunakan: easy, medium, atau hard." to {_p}
                    stop
        set {_scroll} to cs_create_scroll_item({_tier}, {_target})
        give {_scroll} to {_target}
        send "%{cs::config::prefix}%&fBerhasil memberi %cs_tier_display({_tier})% &fScroll kepada &f%name of {_target}%." to {_p}
        send "%{cs::config::prefix}%&fKamu mendapat %cs_tier_display({_tier})% &fClue Scroll! Klik kanan untuk membukanya." to {_target}
        stop

    set {_isReload} to false
    if {_a1} is "reload":
        set {_isReload} to true
    if {_a1} is "rl":
        set {_isReload} to true
    if {_isReload} is true:
        if {_p} doesn't have permission "cluescrolls.reload":
            if {_p} is not op:
                send "%{cs::config::prefix}%&fKamu tidak punya izin." to {_p}
                stop
        send "%{cs::config::prefix}%&fReloading ClueScrolls..." to {_p}
        delete {cs::clues::*}
        delete {cs::rewards::*}
        cs_init_clues()
        cs_init_rewards()
        send "%{cs::config::prefix}%&fClueScrolls berhasil di-reload!" to {_p}
        stop

    set {_isFc} to false
    if {_a1} is "forcecomplete":
        set {_isFc} to true
    if {_a1} is "fc":
        set {_isFc} to true
    if {_isFc} is true:
        if {_p} is not op:
            send "%{cs::config::prefix}%&fHanya OP." to {_p}
            stop
        if {_a2} is not set:
            send "%{cs::config::prefix}%&fPenggunaan: /cs forcecomplete <player>" to {_p}
            stop
        set {_target} to {_a2} parsed as player
        if {_target} is not set:
            send "%{cs::config::prefix}%&fPlayer tidak ditemukan." to {_p}
            stop
        set {_tuid} to cs_get_uid({_target})
        if {_tuid} is not set:
            send "%{cs::config::prefix}%&fPlayer tersebut tidak punya scroll aktif." to {_p}
            stop
        if {_tuid} is "":
            send "%{cs::config::prefix}%&fPlayer tersebut tidak punya scroll aktif." to {_p}
            stop
        cs_complete_scroll({_target})
        send "%{cs::config::prefix}%&fScroll %name of {_target}% diselesaikan paksa." to {_p}
        stop

    set {_isRc} to false
    if {_a1} is "resetcooldown":
        set {_isRc} to true
    if {_a1} is "rc":
        set {_isRc} to true
    if {_isRc} is true:
        if {_p} is not op:
            send "%{cs::config::prefix}%&fHanya OP." to {_p}
            stop
        if {_a2} is not set:
            send "%{cs::config::prefix}%&fPenggunaan: /cs resetcooldown <player> [tier]" to {_p}
            stop
        set {_target} to {_a2} parsed as player
        if {_target} is not set:
            send "%{cs::config::prefix}%&fPlayer tidak ditemukan." to {_p}
            stop
        if {_a3} is set:
            delete {cs::cooldown::%{_target}'s uuid%::%{_a3}%}
        else:
            delete {cs::cooldown::%{_target}'s uuid%::easy}
            delete {cs::cooldown::%{_target}'s uuid%::medium}
            delete {cs::cooldown::%{_target}'s uuid%::hard}
        send "%{cs::config::prefix}%&fCooldown %name of {_target}% direset." to {_p}
        stop

    send "%{cs::config::prefix}%&fPerintah tidak dikenal. Ketik &f/cs &cuntuk bantuan." to {_p}

# Menampilkan statistik scroll milik "target" kepada "viewer" di chat.
# Menampilkan total scroll selesai, total clue selesai, dan jumlah per tier.
function cs_show_stats(viewer: player, target: player):
    set {_sc} to {cs::stats::%{_target}'s uuid%::scrolls_completed}
    set {_cc} to {cs::stats::%{_target}'s uuid%::clues_completed}
    set {_se} to {cs::stats::%{_target}'s uuid%::scrolls_easy}
    set {_sm} to {cs::stats::%{_target}'s uuid%::scrolls_medium}
    set {_sh} to {cs::stats::%{_target}'s uuid%::scrolls_hard}
    if {_sc} is not set:
        set {_sc} to 0
    if {_cc} is not set:
        set {_cc} to 0
    if {_se} is not set:
        set {_se} to 0
    if {_sm} is not set:
        set {_sm} to 0
    if {_sh} is not set:
        set {_sh} to 0

    send "&8&m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━" to {_viewer}
    send "  &6📜 Statistik &f%name of {_target}%" to {_viewer}
    send "" to {_viewer}
    send "  &7Scroll Selesai : &f%{_sc}%" to {_viewer}
    send "  &7Clue Selesai   : &f%{_cc}%" to {_viewer}
    send "" to {_viewer}
    send "  &aEasy   &7: &f%{_se}% &7scroll" to {_viewer}
    send "  &eMedium &7: &f%{_sm}% &7scroll" to {_viewer}
    send "  &cHard   &7: &f%{_sh}% &7scroll" to {_viewer}
    send "&8&m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━" to {_viewer}

# Menampilkan leaderboard 10 player teratas berdasarkan total scroll yang diselesaikan.
# Hanya menampilkan player yang sedang online dan memiliki scroll selesai lebih dari 0.
function cs_show_leaderboard(p: player):
    send "&8&m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━" to {_p}
    send "        &6🏆 &lTop Clue Scrolls" to {_p}
    send "" to {_p}
    set {_rank} to 0
    loop all players:
        if {_rank} >= 10:
            stop loop
        set {_sc} to {cs::stats::%loop-player's uuid%::scrolls_completed}
        if {_sc} is not set:
            set {_sc} to 0
        if {_sc} > 0:
            add 1 to {_rank}
            if {_rank} is 1:
                set {_medal} to "&6#1"
            else if {_rank} is 2:
                set {_medal} to "&7#2"
            else if {_rank} is 3:
                set {_medal} to "&c#3"
            else:
                set {_medal} to "&7#%{_rank}%"
            send "  %{_medal}% &f%name of loop-player% &7- &f%{_sc}% &7scroll" to {_p}
    if {_rank} is 0:
        send "  &7Belum ada data..." to {_p}
    send "&8&m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━" to {_p}

on quit:
    set {_uid} to cs_get_uid(player)
    if {_uid} is set:
        if {_uid} is not "":
            cs_pause_session(player)
    set {cs::lastquit::%player's uuid%} to now
